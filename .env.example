# DateSpot Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Mapbox — PUBLIC access token (for map tiles and search)
# Get from mapbox.com → Account → Access tokens
EXPO_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN

# Mapbox — SECRET downloads token (for SDK install, never prefix with EXPO_PUBLIC_)
# Get from mapbox.com → Account → Access tokens → Create a secret token
# Add to ~/.gradle/gradle.properties on Android:
#   MAPBOX_DOWNLOADS_TOKEN=sk.YOUR_TOKEN
# On iOS it goes in app.json plugin config above (or EAS secrets)
MAPBOX_DOWNLOADS_TOKEN=sk.YOUR_MAPBOX_DOWNLOADS_TOKEN
